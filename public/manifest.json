{
  "manifest_version": 3,
  "name": "ChatGPT Bulk Delete",
  "version": "0.1.0",
  "description": "Adds a stable bulk-selection overlay to the ChatGPT sidebar so selected conversations can be deleted through the existing web UI.",
  "action": {
    "default_title": "ChatGPT Bulk Delete",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
